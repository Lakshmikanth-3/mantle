# ── RPC ──────────────────────────────────────────────────────────────────────
# Alchemy Mantle Sepolia (your key from Alchemy dashboard)
MANTLE_SEPOLIA_RPC_URL=https://mantle-sepolia.g.alchemy.com/v2/vYee8TdhuFySuh7IAItZx
MANTLE_MAINNET_RPC_URL=https://mantle-mainnet.g.alchemy.com/v2/vYee8TdhuFySuh7IAItZx

# Ethereum archive node (needed for historical replay — upgrade your Alchemy plan or use Infura)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/vYee8TdhuFySuh7IAItZx
ETHEREUM_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/vYee8TdhuFySuh7IAItZx

# ── AGENT WALLET ─────────────────────────────────────────────────────────────
# NEVER COMMIT THE REAL KEY — put in .env only
SENTINEL_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
SENTINEL_MANTLE_WALLET=0x_YOUR_WALLET_ADDRESS_HERE

# ── LLM (Google Gemini — FREE TIER) ──────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ── NANSEN ───────────────────────────────────────────────────────────────────
# Apply at DoraHacks resource page ($7,000 in credits)
# Then get key at: https://docs.nansen.ai → Dashboard → API Keys
NANSEN_API_KEY=YOUR_NANSEN_API_KEY_HERE
NANSEN_BASE_URL=https://api.nansen.ai

# ── ELFA AI ──────────────────────────────────────────────────────────────────
# Apply at DoraHacks resource page ($36,000 in credits — Elfa CEO is a judge)
# Then get key at: https://api.elfa.ai → Settings → API Keys
ELFA_API_KEY=YOUR_ELFA_API_KEY_HERE
ELFA_BASE_URL=https://api.elfa.ai/v1

# ── TELEGRAM ─────────────────────────────────────────────────────────────────
# 1. Open Telegram, search for @BotFather
# 2. Send: /newbot
# 3. Name: SENTINEL Mantle Monitor
# 4. Username: sentinel_mantle_bot
# 5. BotFather gives you a token like: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_ALERT_CHANNEL=@sentinel_mantle_alerts
# After creating bot:
# 1. Create a public channel named "SENTINEL Mantle Alerts"
# 2. Username: @sentinel_mantle_alerts
# 3. Add your bot as an ADMIN of the channel

# ── MANTLE FORUM (DISCOURSE) ─────────────────────────────────────────────────
# 1. Create account at forum.mantle.xyz with username: sentinel-agent-021
# 2. Go to: forum.mantle.xyz/u/sentinel-agent-021/preferences/api
# 3. Click "Generate New API Key"
# 4. Description: SENTINEL Agent
# 5. User: sentinel-agent-021
# 6. Scope: All (for now — can restrict later)
DISCOURSE_API_KEY=YOUR_DISCOURSE_API_KEY_HERE
DISCOURSE_USERNAME=sentinel-agent-021
MANTLE_FORUM_URL=https://forum.mantle.xyz
DISCOURSE_CATEGORY_ID=9

# ── WEB3.STORAGE (IPFS for agent card) ────────────────────────────────────────
# 1. Go to: https://web3.storage
# 2. Sign up → Create API Token → Copy
WEB3_STORAGE_TOKEN=YOUR_WEB3_STORAGE_TOKEN_HERE

# ── ERC-8004 REGISTRY ADDRESSES (Mantle Mainnet) ─────────────────────────────
# From: https://github.com/sudeepb02/awesome-erc8004
ERC8004_IDENTITY_REGISTRY=0x8004A169D339Cc92C2FA41EDCEA62E8f05C0000
ERC8004_REPUTATION_REGISTRY=0x8004B1234567890abcdef1234567890abcdef12
ERC8004_VALIDATION_REGISTRY=0x8004C1234567890abcdef1234567890abcdef34

# ── DEPLOYED CONTRACT ADDRESSES (fill after deployment) ───────────────────────
SENTINEL_CORE_ADDRESS=
SENTINEL_LEDGER_ADDRESS=
SENTINEL_VERIFIER_ADDRESS=

# ── BRIDGE ADDRESSES ──────────────────────────────────────────────────────────
# rsETH OFT Adapter on Ethereum (verified from Innora.ai forensic analysis)
RSETH_ETH_BRIDGE=0x85d456b2dff1fd8245387c0bfb64dfb700e98ef3
# rsETH OFT on Mantle (get from official Kelp DAO docs)
RSETH_MANTLE_OFT=0x

# ── BYREAL / SUPER PORTAL ─────────────────────────────────────────────────────
BYREAL_SOLANA_WALLET=YOUR_SOLANA_WALLET_HERE
SUPER_PORTAL_ADDRESS=0x

# ── INDEXER ───────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel
WEBSOCKET_PORT=3001

# ── ORACLE SERVER ─────────────────────────────────────────────────────────────
ORACLE_PORT=3002
ORACLE_PAYMENT_AMOUNT=0.05
